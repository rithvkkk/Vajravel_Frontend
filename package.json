{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Vajravel Crackers Point of Sale System",
  "author": "Vajravel POS Team",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && npx electron-builder",
    "cap:init": "cap init \"Vajravel POS\" com.vajravel.pos --web-dir dist",
    "cap:add-android": "cap add android",
    "cap:sync": "vite build && cap sync"
  },
  "build": {
    "appId": "com.vajravel.pos",
    "productName": "Vajravel POS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.jpg"
    }
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "dexie": "^4.3.0",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^5.4.21"
  }
}
